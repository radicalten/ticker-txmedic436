# Chess 3DS Engine - Performance Analysis & Optimization Opportunities

## Critical Bottlenecks Identified

### 1. `gui_has_legal_moves()` - Most Expensive Function

```c
// CURRENT: O(64 * 64) = 4096 calls to gui_is_legal_move each checking pseudo-legality
// + making a full board copy + king search + attack detection
int gui_has_legal_moves(const GuiBoardState *state) {
    for (int f = 0; f < 64; f++) {
        for (int t = 0; t < 64; t++) {  // 4096 iterations worst case
            GuiMove m = {f, t, 0};
            if (gui_is_legal_move(state, m)) return 1;
        }
    }
    return 0;
}
```

**Optimized version:**
```c
int gui_has_legal_moves(const GuiBoardState *state) {
    for (int f = 0; f < 64; f++) {
        int p = state->board[f];
        // Skip empty squares and opponent pieces immediately
        if (p == 0) continue;
        if (state->turn == 1 && p < 0) continue;
        if (state->turn == -1 && p > 0) continue;

        int fr = f / 8, fc = f % 8;
        int abs_p = abs(p);

        // Generate only geometrically reachable targets per piece type
        // instead of blindly testing all 64 squares
        switch (abs_p) {
            case 1: { // Pawn - maximum 4 possible target squares
                int dir = (state->turn == 1) ? -1 : 1;
                int targets[4];
                int tc = 0;
                // Forward one
                int fwd = f + dir * 8;
                if (fwd >= 0 && fwd < 64) targets[tc++] = fwd;
                // Forward two from start rank
                int start_r = (state->turn == 1) ? 6 : 1;
                if (fr == start_r) {
                    int fwd2 = f + dir * 16;
                    if (fwd2 >= 0 && fwd2 < 64) targets[tc++] = fwd2;
                }
                // Diagonal captures
                if (fc > 0) targets[tc++] = f + dir * 8 - 1;
                if (fc < 7) targets[tc++] = f + dir * 8 + 1;
                for (int i = 0; i < tc; i++) {
                    int t = targets[i];
                    if (t < 0 || t >= 64) continue;
                    GuiMove m = {f, t, 0};
                    if (t / 8 == 0 || t / 8 == 7) m.promo = 5;
                    if (gui_is_legal_move(state, m)) return 1;
                }
                break;
            }
            case 2: { // Knight - maximum 8 squares
                static const int kdr[] = {-2,-2,-1,-1, 1, 1, 2, 2};
                static const int kdc[] = {-1, 1,-2, 2,-2, 2,-1, 1};
                for (int i = 0; i < 8; i++) {
                    int nr = fr + kdr[i], nc = fc + kdc[i];
                    if (nr < 0 || nr > 7 || nc < 0 || nc > 7) continue;
                    GuiMove m = {f, nr * 8 + nc, 0};
                    if (gui_is_legal_move(state, m)) return 1;
                }
                break;
            }
            case 3: { // Bishop - diagonals only
                static const int bdr[] = {-1,-1, 1, 1};
                static const int bdc[] = {-1, 1,-1, 1};
                for (int d = 0; d < 4; d++) {
                    int nr = fr + bdr[d], nc = fc + bdc[d];
                    while (nr >= 0 && nr < 8 && nc >= 0 && nc < 8) {
                        GuiMove m = {f, nr * 8 + nc, 0};
                        if (gui_is_legal_move(state, m)) return 1;
                        // Stop ray on any piece
                        if (state->board[nr * 8 + nc] != 0) break;
                        nr += bdr[d]; nc += bdc[d];
                    }
                }
                break;
            }
            case 4: { // Rook - ranks and files
                static const int rdr[] = {-1, 1, 0, 0};
                static const int rdc[] = { 0, 0,-1, 1};
                for (int d = 0; d < 4; d++) {
                    int nr = fr + rdr[d], nc = fc + rdc[d];
                    while (nr >= 0 && nr < 8 && nc >= 0 && nc < 8) {
                        GuiMove m = {f, nr * 8 + nc, 0};
                        if (gui_is_legal_move(state, m)) return 1;
                        if (state->board[nr * 8 + nc] != 0) break;
                        nr += rdr[d]; nc += rdc[d];
                    }
                }
                break;
            }
            case 5: { // Queen - all 8 directions as rays
                static const int qdr[] = {-1,-1,-1, 0, 0, 1, 1, 1};
                static const int qdc[] = {-1, 0, 1,-1, 1,-1, 0, 1};
                for (int d = 0; d < 8; d++) {
                    int nr = fr + qdr[d], nc = fc + qdc[d];
                    while (nr >= 0 && nr < 8 && nc >= 0 && nc < 8) {
                        GuiMove m = {f, nr * 8 + nc, 0};
                        if (gui_is_legal_move(state, m)) return 1;
                        if (state->board[nr * 8 + nc] != 0) break;
                        nr += qdr[d]; nc += qdc[d];
                    }
                }
                break;
            }
            case 6: { // King - adjacent + castling
                static const int kgdr[] = {-1,-1,-1, 0, 0, 1, 1, 1};
                static const int kgdc[] = {-1, 0, 1,-1, 1,-1, 0, 1};
                for (int i = 0; i < 8; i++) {
                    int nr = fr + kgdr[i], nc = fc + kgdc[i];
                    if (nr < 0 || nr > 7 || nc < 0 || nc > 7) continue;
                    GuiMove m = {f, nr * 8 + nc, 0};
                    if (gui_is_legal_move(state, m)) return 1;
                }
                // Castling candidates
                if (state->turn == 1 && f == 60) {
                    GuiMove m1 = {60, 62, 0};
                    GuiMove m2 = {60, 58, 0};
                    if (gui_is_legal_move(state, m1)) return 1;
                    if (gui_is_legal_move(state, m2)) return 1;
                } else if (state->turn == -1 && f == 4) {
                    GuiMove m1 = {4, 6, 0};
                    GuiMove m2 = {4, 2, 0};
                    if (gui_is_legal_move(state, m1)) return 1;
                    if (gui_is_legal_move(state, m2)) return 1;
                }
                break;
            }
        }
    }
    return 0;
}
```
**Expected gain: ~20-40x fewer `gui_is_legal_move` calls in typical positions**

