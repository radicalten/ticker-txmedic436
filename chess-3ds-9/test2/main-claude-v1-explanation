**Fix - maintain an incrementally updated position string:**
```c
// Global persistent position command buffer
static char position_cmd[8192] = "position startpos";
static int position_cmd_len = 17;
static int position_cmd_moves_count = 0; // Moves already appended

void append_move_to_position_cmd(GuiMove m) {
    char uci_m[10];
    move_to_uci(m, uci_m);
    int move_len = strlen(uci_m);
    
    if (position_cmd_moves_count == 0) {
        // First move: append " moves" prefix
        strcpy(position_cmd + position_cmd_len, " moves");
        position_cmd_len += 6;
    }
    
    position_cmd[position_cmd_len++] = ' ';
    strcpy(position_cmd + position_cmd_len, uci_m);
    position_cmd_len += move_len;
    position_cmd[position_cmd_len] = '\0';
    position_cmd_moves_count++;
}

// Reset on new game / undo (undo requires rebuild from history)
void reset_position_cmd(void) {
    strcpy(position_cmd, "position startpos");
    position_cmd_len = 17;
    position_cmd_moves_count = 0;
}
```

