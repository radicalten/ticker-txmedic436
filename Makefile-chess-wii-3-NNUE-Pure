#arch = ppc
#bits = 32

.SUFFIXES:
export DEVKITPRO 	:= /opt/devkitpro
export DEVKITPPC	:= $(DEVKITPRO)/devkitPPC
include $(DEVKITPPC)/wii_rules
CC 					:= $(DEVKITPPC)/bin/powerpc-eabi-gcc
OBJCOPY 			:= $(DEVKITPPC)/bin/powerpc-eabi-objcopy
MACHDEP := -DGEKKO -mrvl -mcpu=750 -meabi -mhard-float -fsigned-char -ffast-math -funroll-loops -fauto-inc-dec -finline-functions
INCLUDES += -I/opt/devkitpro/portlibs/wii/include -I/opt/devkitpro/portlibs/ppc/include -I/opt/devkitpro/libogc/include
CFLAGS 	+= -O3 -flto \
$(INCLUDES) $(MACHDEP) \
-DIS_32BIT -DNNUE -DNNUE_EMBEDDED -DNNUE_PURE
LDFLAGS += $(CFLAGS) \
-Wl,-Map,$(notdir $@).map \
-L/opt/devkitpro/portlibs/wii/lib \
-L/opt/devkitpro/portlibs/ppc/lib \
-L/opt/devkitpro/libogc/lib \
-L/opt/devkitpro/libogc/lib/wii \
-lwiikeyboard -lfat -lwiiuse -lbte -logc -lm
TARGET  := myapp
EXCLUDE := chess-wii-2/numa.c
SRCDIR 	:= chess-wii-2
C_SOURCES = $(foreach dir, $(SRCDIR), $(filter-out $(EXCLUDE), $(wildcard $(dir)/*.c)))
SOURCES = $(C_SOURCES) 
NNUE    := chess3/nn-62ef826d1a6d.nnue
OBJECTS = $(SOURCES:.c=.o) network.o

ELF2DOL     := elf2dol

all: $(TARGET).dol
$(TARGET).dol: $(TARGET).elf
	$(ELF2DOL) $< $@

$(TARGET).elf: $(OBJECTS)
	$(CC) $^ -o $@ $(LDFLAGS)

%.o: %.c
	$(CC) -c $< -o $@ $(CFLAGS)

network.o: $(NNUE)
	cp $< network.bin
	$(OBJCOPY) -I binary -O elf32-powerpc -B powerpc:common network.bin $@
	rm network.bin

clean:
	rm -f $(TARGET).elf $(TARGET).dol $(TARGET).map $(OBJECTS) network.bin

.PHONY: clean test
