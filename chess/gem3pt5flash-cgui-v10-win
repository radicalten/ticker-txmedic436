/* --- CONSTANTS & CONFIGURATION --- */
#define EMPTY 0
#define PAWN 1
#define KNIGHT 2
#define BISHOP 3
#define ROOK 4
#define QUEEN 5
#define KING 6

#define WHITE 1
#define BLACK -1
#define MAX_MOVES 1024

/* --- DATA STRUCTURES --- */
typedef struct {
    int from_r, from_c;
    int to_r, to_c;
    char promo; // 'q', 'r', 'b', 'n' or 0
} Move;

typedef struct {
    int board[8][8];
    int active_color; // 1 = White, -1 = Black
    bool w_castle_k, w_castle_q;
    bool b_castle_k, b_castle_q;
    int ep_c; // En-passant column target (-1 if none)
    int halfmove;
    int fullmove;
} BoardState;

typedef struct {
    BoardState states[MAX_MOVES];
    Move moves[MAX_MOVES];
    char pgn_strings[MAX_MOVES][16];
    int count;
} GameHistory;

typedef struct {
    Move moves[256];
    int count;
} MoveList;

/* --- GLOBAL STATES --- */
struct termios orig_termios;
int engine_to_pip[2];
int engine_from_pip[2];
pid_t engine_pid = -1;
bool engine_thinking = false;
char engine_buf[4096];
int engine_buf_len = 0;

BoardState current_state;
