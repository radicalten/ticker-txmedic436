    if (epath[0]) {
        if (access(epath, X_OK) != 0) {
            move_cursor(8,3);
            printf(FG_ERR "Warning: cannot execute '%s'. Continuing anyway." ANSI_RESET, epath);
            usleep(1500000);
        }
