int engine_buf_len = 0;

void check_engine(int cursor_sq, int selected_sq, int *valid_targets) {
    if (!engine_active) return;
    char temp[512];
    int n;
    while ((n = read(from_engine[0], temp, sizeof(temp) - 1)) > 0) {
        temp[n] = '\0';
        if (engine_buf_len + n < (int)sizeof(engine_buf)) {
            memcpy(engine_buf + engine_buf_len, temp, n);
            engine_buf_len += n;
            engine_buf[engine_buf_len] = '\0';
        } else {
            engine_buf_len = 0;
        }
    }
    char *line;
    while ((line = strchr(engine_buf, '\n')) != NULL) {
        *line = '\0';
        char *curr_line = engine_buf;
        if (strncmp(curr_line, "bestmove", 8) == 0) {
            char bestmove[16];
            if (sscanf(curr_line, "bestmove %s", bestmove) == 1) {
                if (strcmp(bestmove, "(none)") != 0 && engine_thinking) {
                    int from, to, promo;
                    uci_to_move(&board_history[history_count], bestmove, &from, &to, &promo);
                    char pgn[16];
                    get_pgn_move_string(&board_history[history_count], from, to, promo, pgn);

                    board_history[history_count + 1] = board_history[history_count];
                    make_move(&board_history[history_count + 1], from, to, promo);

                    move_history[history_count].from = from;
                    move_history[history_count].to = to;
                    move_history[history_count].promotion = promo;
                    strcpy(move_history[history_count].pgn, pgn);

                    history_count++;
                    engine_thinking = 0;
                    draw_board(&board_history[history_count], cursor_sq, selected_sq, valid_targets);
                }
            }
        }
        int len = line + 1 - engine_buf;
        memmove(engine_buf, line + 1, engine_buf_len - len + 1);
        engine_buf_len -= len;
    }
}

int main() {
    start_engine();
    init_board(&board_history[0]);

    int cursor_sq = 60; // Standard e1 start square
    int selected_sq = -1;
    int valid_targets[64];
    valid_targets[0] = -1;

    enableRawMode();
    draw_board(&board_history[0], cursor_sq, selected_sq, valid_targets);

    while (1) {
        check_engine(cursor_sq, selected_sq, valid_targets);

        fd_set read_fds;
        FD_ZERO(&read_fds);
        FD_SET(STDIN_FILENO, &read_fds);
        int max_fd = STDIN_FILENO;
        if (engine_active) {
            FD_SET(from_engine[0], &read_fds);
            if (from_engine[0] > max_fd) max_fd = from_engine[0];
        }

        struct timeval tv = {0, 50000}; // 50ms async update intervals
        int sr = select(max_fd + 1, &read_fds, NULL, NULL, &tv);

        if (sr > 0) {
            if (engine_active && FD_ISSET(from_engine[0], &read_fds)) {
                check_engine(cursor_sq, selected_sq, valid_targets);
            }
            if (FD_ISSET(STDIN_FILENO, &read_fds)) {
                int k = read_key();
                if (k == 'q' || k == 'Q') break;
                else if (k == KEY_UP && cursor_sq >= 8) cursor_sq -= 8;
                else if (k == KEY_DOWN && cursor_sq < 56) cursor_sq += 8;
                else if (k == KEY_LEFT && cursor_sq % 8 > 0) cursor_sq -= 1;
                else if (k == KEY_RIGHT && cursor_sq % 8 < 7) cursor_sq += 1;
                else if (k == ' ' || k == '\r' || k == '\n') {
                    if (selected_sq == -1) {
                        int p = board_history[history_count].pieces[cursor_sq];
                        if (p && GET_COLOR(p) == board_history[history_count].side) {
                            selected_sq = cursor_sq;
                            generate_moves(&board_history[history_count], selected_sq, valid_targets);
                        }
                    } else {
                        int is_valid = 0;
                        for (int i = 0; valid_targets[i] != -1; i++) {
                            if (valid_targets[i] == cursor_sq) { is_valid = 1; break; }
                        }
                        if (is_valid) {
                            int promo = EMPTY;
                            int p = board_history[history_count].pieces[selected_sq];
                            if (GET_TYPE(p) == P && (cursor_sq / 8 == 0 || cursor_sq / 8 == 7)) {
                                promo = get_promotion_piece();
                            }
                            char pgn[16];
                            get_pgn_move_string(&board_history[history_count], selected_sq, cursor_sq, promo, pgn);

                            board_history[history_count + 1] = board_history[history_count];
                            make_move(&board_history[history_count + 1], selected_sq, cursor_sq, promo);

                            move_history[history_count].from = selected_sq;
                            move_history[history_count].to = cursor_sq;
                            move_history[history_count].promotion = promo;
                            strcpy(move_history[history_count].pgn, pgn);

                            history_count++;
                            selected_sq = -1;
                            valid_targets[0] = -1;
                            sync_engine();

                            if (play_vs_engine && engine_active) {
                                send_to_engine("go movetime 1000");
                                engine_thinking = 1;
                            }
                        } else {
                            int p = board_history[history_count].pieces[cursor_sq];
                            if (p && GET_COLOR(p) == board_history[history_count].side) {
                                selected_sq = cursor_sq;
                                generate_moves(&board_history[history_count], selected_sq, valid_targets);
                            } else {
                                selected_sq = -1;
                                valid_targets[0] = -1;
                            }
                        }
                    }
                } else if (k == 'u' || k == 'U') {
                    int undo_steps = (play_vs_engine) ? 2 : 1;
                    if (history_count >= undo_steps) {
                        history_count -= undo_steps;
                        selected_sq = -1;
                        valid_targets[0] = -1;
                        sync_engine();
                    }
                } else if (k == 'r' || k == 'R') {
                    history_count = 0;
                    selected_sq = -1;
                    valid_targets[0] = -1;
                    init_board(&board_history[0]);
                    sync_engine();
                } else if (k == 'e' || k == 'E') {
                    play_vs_engine = !play_vs_engine;
                    if (play_vs_engine && board_history[history_count].side == BLACK && engine_active) {
                        send_to_engine("go movetime 1000");
                        engine_thinking = 1;
                    }
                }
                draw_board(&board_history[history_count], cursor_sq, selected_sq, valid_targets);
            }
        }

        if (play_vs_engine && board_history[history_count].side == BLACK && engine_active && !engine_thinking) {
            send_to_engine("go movetime 1000");
            engine_thinking = 1;
        }

        if (engine_thinking) {
            printf("\r \033[1;33mEngine is thinking...\033[0m   ");
            fflush(stdout);
        }
    }

    if (engine_active) {
        send_to_engine("quit");
        close(to_engine[1]);
        close(from_engine[0]);
        kill(engine_pid, SIGTERM);
    }
    disableRawMode();
    printf("\nThanks for playing!\n");
    return 0;
}
