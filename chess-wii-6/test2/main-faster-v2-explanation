### 5. `fifo_write()` — Character-by-Character Loop

```c
// CURRENT: One character at a time with modulo per character
void fifo_write(SimpleFIFO *f, const char *str, int len) {
    int h = f->head;
    int t = f->tail;
    for (int i = 0; i < len; i++) {
        int next = (h + 1) % FIFO_SIZE;  // Modulo every iteration!
        if (next == t) break;
        f->data[h] = str[i];
        h = next;
    }
    __sync_synchronize();
    f->head = h;
}
```

**Fix:** Use `memcpy` for contiguous segments. The PowerPC 750CL (Broadway) has hardware-accelerated cache line fills:

```c
void fifo_write(SimpleFIFO *f, const char *str, int len) {
    if (!f || !str || len <= 0) return;
    
    int h = f->head;
    int t = f->tail;
    
    // Available space (leave 1 slot empty to distinguish full vs empty)
    int avail = (t - h - 1 + FIFO_SIZE) % FIFO_SIZE;
    if (len > avail) len = avail;
    if (len == 0) return;
    
    // Contiguous space to end of buffer
    int space_to_end = FIFO_SIZE - h;
    
    if (len <= space_to_end) {
        // Single memcpy — no wraparound
        memcpy(&f->data[h], str, len);
    } else {
        // Two memcpys: end of buffer + wrap to start
        memcpy(&f->data[h], str, space_to_end);
        memcpy(&f->data[0], str + space_to_end, len - space_to_end);
    }
    
    __sync_synchronize();
    f->head = (h + len) % FIFO_SIZE;
}
```

Apply the same pattern to `fifo_read()`:

```c
int fifo_read(SimpleFIFO *f, char *out, int max_len) {
    if (!f || !out || max_len <= 0) return 0;
    
    int t = f->head;  // snapshot head
    int h = f->tail;
    if (h == t) return 0;
    
    // Actually: tail is read pointer, head is write pointer
    // Reusing variable names from original — keeping original semantics:
    int available = (f->head - f->tail + FIFO_SIZE) % FIFO_SIZE;
    int len = (available < max_len) ? available : max_len;
    
    int tail = f->tail;
    int to_end = FIFO_SIZE - tail;
    
    if (len <= to_end) {
        memcpy(out, &f->data[tail], len);
    } else {
        memcpy(out, &f->data[tail], to_end);
        memcpy(out + to_end, &f->data[0], len - to_end);
    }
    
    __sync_synchronize();
    f->tail = (tail + len) % FIFO_SIZE;
    return len;
}
```

