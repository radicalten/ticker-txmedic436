.SUFFIXES:
export DEVKITPRO 	:= /opt/devkitpro
export DEVKITARM	:= $(DEVKITPRO)/devkitARM
#export LIBTONC 	:= $(DEVKITPRO)/libtonc
include $(DEVKITARM)/gba_rules
CC 					:= $(DEVKITARM)/bin/arm-none-eabi-gcc
NM                  := $(DEVKITARM)/bin/arm-none-eabi-nm

MACHDEP := -D__GBA__ -mthumb -mthumb-interwork -mcpu=arm7tdmi -mtune=arm7tdmi -fomit-frame-pointer -ffast-math -funroll-loops
INCLUDES += -I/opt/devkitpro/portlibs/arm-none-eabi/include -I/opt/devkitpro/libtonc/include -I/opt/devkitpro/libgba/include
CFLAGS 	:= -Os \
$(INCLUDES) $(MACHDEP) \
-DNO_NNUE
LDFLAGS := $(CFLAGS) \
-specs=gba.specs \
-Wl,-Map,$(TARGET).map \
-L/opt/devkitpro/portlibs/arm-none-eabi/lib \
-L/opt/devkitpro/libtonc/lib \
-L/opt/devkitpro/libgba/lib \
-lmm -ltonc -lm
TARGET  := myapp
EXCLUDE := chess-GBA-2/nnue.c chess-GBA-2/numa.c
SRCDIR 	:= chess-GBA-2
C_SOURCES = $(foreach dir, $(SRCDIR), $(filter-out $(EXCLUDE), $(wildcard $(dir)/*.c)))
SOURCES = $(C_SOURCES) 
OBJECTS = $(SOURCES:.c=.o)

all: $(TARGET).gba

# Build ELF (and analyze sizes before linking)
$(TARGET).elf: $(OBJECTS)
	@echo "=========================================================="
	@echo "ANALYSIS: Top 100 Largest Variables in Compiled Object Files"
	@echo "=========================================================="
	-$(NM) --size-sort -S -r $(OBJECTS) | head -n 100
	@echo "=========================================================="
	$(CC) $^ -o $@ $(LDFLAGS)

# Package ELF into .gba (requires devkitPro tools)
$(TARGET).gba: $(TARGET).elf 
	$(OBJCOPY) -O binary $< $@
	gbafix $(TARGET).elf $(TARGET).gba 

%.o: %.c
	$(CC) -c $< -o $@ $(CFLAGS)

clean:
	rm -f $(TARGET).elf $(TARGET).gba $(TARGET).map $(OBJECTS)

.PHONY: all clean
