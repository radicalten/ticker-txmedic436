CC		:= cc
CFLAGS 	:= -O3 -flto \
-DNO_NNUE -D__APPLE__ -march=native -DUSE_PREFETCH -DUSE_POPCNT -DUSE_NEON
LDFLAGS := $(CFLAGS) \
-lcurl -lm
TARGET  := myapp
EXCLUDE := chess3/nnue.c chess3/numa.c
SRCS    := $(filter-out $(EXCLUDE), $(wildcard chess3/*.c))
OBJS    := $(patsubst %.c,%.o,$(SRCS))
all: $(OBJS)
	$(CC) $(OBJS) $(CFLAGS) $(LDFLAGS) -o $(TARGET) 
%.o: %.c
	$(CC) $(CFLAGS) -c $< -o $@
