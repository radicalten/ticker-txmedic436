CC		:= cc
CFLAGS 	:= -O3 -flto \
-DNNUE -DNNUE_EMBEDDED -D__APPLE__ -march=native -DUSE_PREFETCH -DUSE_POPCNT -DUSE_NEON
LDFLAGS := $(CFLAGS) \
-lcurl -lm
TARGET  := myapp
SRCS    := $(wildcard chess3/*.c)
OBJS    := $(patsubst %.c,%.o,$(SRCS)) network.o
all: $(OBJS)
	$(CC) $(OBJS) $(CFLAGS) $(LDFLAGS) -o $(TARGET) 
%.o: %.c
	$(CC) $(CFLAGS) -c $< -o $@
network.o: chess3/nn-62ef826d1a6d.nnue
	@echo "Embedding chess3/nn-62ef826d1a6d.nnue..."
	@echo '.section __TEXT,__const' > network.s
	@echo '.globl __binary_nn_62ef826d1a6d_nnue_start' >> network.s
	@echo '.globl __binary_nn_62ef826d1a6d_nnue_end' >> network.s
	@echo '.balign 4096' >> network.s
	@echo '__binary_nn_62ef826d1a6d_nnue_start:' >> network.s
	@echo '.incbin "chess3/nn-62ef826d1a6d.nnue"' >> network.s  <-- Points to the subfolder
	@echo '__binary_nn_62ef826d1a6d_nnue_end:' >> network.s
	$(CC) $(CFLAGS) -c network.s -o network.o
	@rm -f network.s
