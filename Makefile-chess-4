CC		:= cc
CFLAGS 	:= -O3 -flto \
-DNNUE -DNNUE_EMBEDDED -D__APPLE__ -march=native -DUSE_PREFETCH -DUSE_POPCNT -DUSE_NEON
LDFLAGS := $(CFLAGS) \
-lcurl -lm
TARGET  := myapp
SRCS    := $(wildcard chess3/*.c)
NNUE    := chess3/nn-62ef826d1a6d.nnue
OBJS    := $(patsubst %.c,%.o,$(SRCS)) network.o
all: $(OBJS)
	$(CC) $(OBJS) $(CFLAGS) $(LDFLAGS) -o $(TARGET) 
%.o: %.c
	$(CC) $(CFLAGS) -c $< -o $@
# Generate a stub so ld has at least one object file
stub.c:
	@echo "// stub" > stub.c

stub.o: stub.c
	$(CC) -arch arm64 -c stub.c -o stub.o

network.o: stub.o $(NNUE)
	ld -r -arch arm64 -o network.o stub.o \
		-sectcreate binary network_nnue $(NNUE)

clean:
	rm -f $(OBJS) $(TARGET) dummy.o
